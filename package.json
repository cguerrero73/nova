{
  "name": "nova",
  "version": "1.0.0",
  "description": "Nova - Internal Framework for Rapid Application Development",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "overrides": {
    "typescript": "~5.8.0",
    "ts-api-utils": {
      "typescript": "~5.8.0"
    }
  },
  "scripts": {
    "dev": "make dev",
    "build": "make build",
    "test": "make test",
    "lint": "make lint",
    "db:migrate": "cd backend && ./nova-migrate -type=global up && ./nova-migrate -type=tenant -tenant=demo up",
    "db:seed": "cd backend && ./nova-migrate -type=global seed && ./nova-migrate -type=tenant -tenant=demo seed"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@tanstack/angular-table": "^8.21.3"
  }
}
